# VS Code settings (keep settings.json, ignore the rest).
# Must use .vscode/* not .vscode/ -- git cannot re-include a file whose
# parent directory is excluded wholesale. Inline "# ..." comments after a
# pattern are not supported by git, so keep comments on their own lines.
.vscode/*
!.vscode/settings.json

# Markdown linting configuration (keep local)
.markdownlint.json

# AI assistant config (personal, not for public repo)
CLAUDE.md

# Temporary files
*.tmp
*.temp
*.log
*.cache
*.bak
*.old
*~
.DS_Store
Thumbs.db

# Resume lives in latex-resume releases; not stored in this repo

# Backup files (from validate script)
*.backup-*

# Environment files
.env
.env.local
.env.*.local

# Node modules (if you add any JS tooling)
node_modules/

# Python cache (if you add any Python scripts)
__pycache__/
*.pyc
